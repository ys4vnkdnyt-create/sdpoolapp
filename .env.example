# Copy to .env and fill in locally — never commit .env
OPENAI_API_KEY=sk-your-key-here
# Optional: slower/faster pause between ingest HTTP requests (milliseconds)
# INGEST_DELAY_MS=800
# Optional: OpenAI model for schedule transcription
# OPENAI_MODEL=gpt-4o-mini
# Optional: vision model for PDF grid schedules (recommended for YMCA PDFs)
# OPENAI_VISION_MODEL=gpt-4o
